{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "process-monitor",
  "version": "0.1.0",
  "identifier": "com.feng.process-monitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Process Monitor",
        "width": 1000,
        "height": 700,
        "visible": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost data:",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "object-src": "'none'",
        "base-uri": "'self'",
        "frame-ancestors": "'none'",
        "form-action": "'none'"
      },
      "devCsp": {
        "default-src": "'self'",
        "script-src": "'self' 'unsafe-inline' 'unsafe-eval' http://localhost:1420",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost data: blob:",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost ws://localhost:1420 http://localhost:1420",
        "object-src": "'none'",
        "base-uri": "'self'",
        "frame-ancestors": "'none'",
        "form-action": "'none'"
      },
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "Cross-Origin-Opener-Policy": "same-origin",
        "Cross-Origin-Resource-Policy": "same-origin",
        "Permissions-Policy": [
          "accelerometer=()",
          "camera=()",
          "geolocation=()",
          "gyroscope=()",
          "magnetometer=()",
          "microphone=()",
          "payment=()",
          "usb=()",
          "midi=()",
          "bluetooth=()",
          "serial=()",
          "hid=()",
          "idle-detection=()",
          "interest-cohort=()"
        ]
      },
      "capabilities": [
        {
          "identifier": "main-capability",
          "windows": [
            "main"
          ],
          "permissions": [
            "core:default",
            "core:window:allow-close",
            "core:window:allow-hide",
            "core:window:allow-show",
            "core:window:allow-set-focus",
            "core:window:allow-set-size",
            "core:window:allow-inner-size",
            "core:window:allow-create",
            "core:webview:default",
            "core:webview:allow-create-webview-window",
            "core:event:default",
            "core:event:allow-emit",
            "core:event:allow-listen"
          ]
        },
        {
          "identifier": "alert-capability",
          "windows": [
            "alert-*"
          ],
          "permissions": [
            "core:default",
            "core:window:allow-close",
            "core:window:allow-start-dragging",
            "core:window:allow-hide",
            "core:window:allow-show"
          ]
        },
        {
          "identifier": "notif-capability",
          "windows": [
            "notif-*"
          ],
          "permissions": [
            "core:default",
            "core:window:allow-close",
            "core:window:allow-hide",
            "core:window:allow-show",
            "core:window:allow-set-size",
            "core:window:allow-inner-size",
            "core:event:default",
            "core:event:allow-listen"
          ]
        },
        {
          "identifier": "opener-capability",
          "windows": [
            "main",
            "alert-*",
            "notif-*"
          ],
          "permissions": [
            "opener:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/icon_512x512.png",
      "icons/icon_1024x1024.png",
      "icons/Square30x30Logo.png",
      "icons/Square44x44Logo.png",
      "icons/Square71x71Logo.png",
      "icons/Square89x89Logo.png",
      "icons/Square107x107Logo.png",
      "icons/Square142x142Logo.png",
      "icons/Square150x150Logo.png",
      "icons/Square284x284Logo.png",
      "icons/Square310x310Logo.png",
      "icons/StoreLogo.png"
    ]
  },
  "plugins": {
    "notification": null,
    "autostart": null
  }
}